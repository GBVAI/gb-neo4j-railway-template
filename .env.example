# Build-time override. Railway will pass this into Docker builds if the template
# defines it as a service variable and the Dockerfile declares ARG with the same name.
RAILWAY_NEO4J_IMAGE_TAG=5.26.22-community-trixie

# Recommended template-generated runtime auth.
NEO4J_PASSWORD=replace-me-with-a-generated-secret

# Optional full auth override. If set, this wins over NEO4J_PASSWORD.
# NEO4J_AUTH=neo4j/replace-me

# Recommended starter memory profile.
NEO4J_server_memory_heap_initial__size=1G
NEO4J_server_memory_heap_max__size=4G
NEO4J_server_memory_pagecache_size=4G
NEO4J_dbms_memory_transaction_total_max=1G

# Friendly comma-separated plugin selection. The wrapper converts this to the
# JSON format expected by the official Neo4j image.
NEO4J_PLUGINS_LIST=apoc

# Examples:
# NEO4J_PLUGINS_LIST=apoc,n10s
# NEO4J_PLUGINS_LIST=apoc,graph-data-science
# NEO4J_PLUGINS_LIST=apoc,n10s,graph-data-science

# Optional security and APOC toggles.
# NEO4J_PROCEDURES_UNRESTRICTED=apoc.*
# NEO4J_PROCEDURES_ALLOWLIST=apoc.*
# NEO4J_ENABLE_FILE_IMPORT=false
# NEO4J_ENABLE_FILE_EXPORT=false
